    .filter(n => n.type === 'nameExtractor')
    .map(n => `<option value="nameExtractor:${n.shortId}">${n.shortId} (Nome Extraído)</option>`);

    return [...inputVariables, ...apiVariables, ...aiVariables, ...nameExtractorVariables].join('');
}
