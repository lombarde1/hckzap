        if (inputKeyElement) {
            node.inputKey = inputKeyElement.value;
        }
        if (saveResponseElement) {
            node.saveResponse = saveResponseElement.checked;
        }
        node.typeDelay = parseInt(document.getElementById('typeDelay').value) || 0;
